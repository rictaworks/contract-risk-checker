NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:3001
# ローカル開発のみ: true にすると Google 認証をバイパスして固定セッションを返す（フロントエンド全体）。
# authOptions・ログイン画面・APIクライアントの判定を統一するため NEXT_PUBLIC_ を使用。
# 本番・CI・共有環境では設定禁止。
NEXT_PUBLIC_DEV_AUTH_BYPASS=
